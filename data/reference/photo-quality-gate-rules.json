{
  "name": "Photo Quality Gate Rules",
  "purpose": "Defines the comparison-readiness warning system for the future Cane Corso visual match model.",
  "version": "0.1",
  "decision_bands": [
    {
      "level": "accepted",
      "score_range": "80-100",
      "comparison_allowed": true,
      "meaning": "The photo is suitable for visual geometry comparison."
    },
    {
      "level": "limited",
      "score_range": "55-79",
      "comparison_allowed": true,
      "meaning": "The photo can be reviewed, but the result must be shown as lower-confidence."
    },
    {
      "level": "rejected",
      "score_range": "0-54",
      "comparison_allowed": false,
      "meaning": "The photo should not receive a visual Cane Corso match score."
    }
  ],
  "issues": [
    {
      "id": "full_body_not_visible",
      "weight": 34,
      "blocks_reliable_comparison": true,
