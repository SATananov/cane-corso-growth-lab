    },
    {
      "id": "wrong_view_angle",
      "weight": 30,
      "blocks_reliable_comparison": true,
      "training_label": "wrong_view_type"
    },
    {
      "id": "dog_not_standing",
      "weight": 26,
      "blocks_reliable_comparison": true,
      "training_label": "bad_pose"
    },
    {
      "id": "camera_too_high_or_low",
      "weight": 18,
      "blocks_reliable_comparison": false,
      "training_label": "bad_camera_height"
    },
    {
      "id": "poor_light_or_blur",
      "weight": 20,
